generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SALES
  DELIVERY
  FINANCE
  EXECUTIVE
  ADMIN
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL_SENT
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum ActivityType {
  CALL
  MEETING
  EMAIL
  NOTE
}

enum ProposalStatus {
  DRAFT
  SENT
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum ProjectStatus {
  PLANNING
  EXECUTION
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum HealthScore {
  HEALTHY
  AT_RISK
  CRITICAL
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum QuarterStatus {
  OPEN
  CLOSED
}

enum SnapshotModule {
  CRM
  PROPOSALS
  PROJECTS
  FINANCE
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  name           String?
  role           Role          @default(SALES)
  created_at     DateTime      @default(now())
  
  opportunities  Opportunity[] @relation("OpportunityOwner")
  activities     Activity[]
  projects       Project[]     @relation("ProjectOwner")
  tasks          Task[]        @relation("TaskAssignee")
}

// =====================
// CRM MODULE
// =====================

model Account {
  id             String        @id @default(uuid())
  name           String
  industry       String?
  website        String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  contacts       Contact[]
  opportunities  Opportunity[]
}

model Contact {
  id             String        @id @default(uuid())
  account_id     String
  name           String
  email          String?
  phone          String?
  role           String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  account        Account       @relation(fields: [account_id], references: [id], onDelete: Cascade)
  projects       Project[]     @relation("ClientContact")
}

model Opportunity {
  id                   String            @id @default(uuid())
  account_id           String
  owner_id             String
  name                 String
  stage                OpportunityStage  @default(PROSPECTING)
  value                Decimal           @db.Decimal(12, 2)
  probability          Int               @default(0) // 0 to 100
  expected_close_date  DateTime?
  status               OpportunityStatus @default(OPEN)
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  account              Account           @relation(fields: [account_id], references: [id], onDelete: Cascade)
  owner                User              @relation("OpportunityOwner", fields: [owner_id], references: [id])
  activities           Activity[]
  proposals            Proposal[]
  projects             Project[]
}

model Activity {
  id             String        @id @default(uuid())
  opportunity_id String
  user_id        String
  type           ActivityType
  notes          String?       @db.Text
  date           DateTime      @default(now())

  opportunity    Opportunity   @relation(fields: [opportunity_id], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [user_id], references: [id], onDelete: SetNull)
}

// =====================
// PROPOSAL MODULE
// =====================

model Proposal {
  id             String          @id @default(uuid())
  opportunity_id String
  status         ProposalStatus  @default(DRAFT)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  opportunity    Opportunity     @relation(fields: [opportunity_id], references: [id], onDelete: Cascade)
  versions       ProposalVersion[]
}

model ProposalVersion {
  id             String        @id @default(uuid())
  proposal_id    String
  version_number Int
  document_url   String?
  total_value    Decimal       @db.Decimal(12, 2)
  created_at     DateTime      @default(now())

  proposal       Proposal      @relation(fields: [proposal_id], references: [id], onDelete: Cascade)
}

// =====================
// PROJECT MANAGEMENT
// =====================

model Project {
  id                String        @id @default(uuid())
  opportunity_id    String
  client_contact_id String?
  name              String
  owner_id          String
  status            ProjectStatus @default(PLANNING)
  start_date        DateTime?
  end_date          DateTime?
  sale_value        Decimal       @db.Decimal(12, 2)
  health_score      HealthScore   @default(HEALTHY)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  opportunity       Opportunity   @relation(fields: [opportunity_id], references: [id], onDelete: Restrict)
  client_contact    Contact?      @relation("ClientContact", fields: [client_contact_id], references: [id], onDelete: SetNull)
  owner             User          @relation("ProjectOwner", fields: [owner_id], references: [id])
  
  milestones        Milestone[]
  risks             ProjectRisk[]
  invoices          Invoice[]
  revenue_schedules RevenueSchedule[]
  expenses          Expense[]
}

model Milestone {
  id             String        @id @default(uuid())
  project_id     String
  name           String
  deadline       DateTime?
  status         String        @default("PENDING")
  created_at     DateTime      @default(now())

  project        Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  tasks          Task[]
}

model Task {
  id             String        @id @default(uuid())
  milestone_id   String
  assignee_id    String?
  title          String
  status         String        @default("TODO")
  
  milestone      Milestone     @relation(fields: [milestone_id], references: [id], onDelete: Cascade)
  assignee       User?         @relation("TaskAssignee", fields: [assignee_id], references: [id], onDelete: SetNull)
}

model ProjectRisk {
  id             String        @id @default(uuid())
  project_id     String
  description    String
  severity       String        // LOW, MEDIUM, HIGH
  status         String        @default("OPEN")

  project        Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

// =====================
// FINANCIAL MODULE
// =====================

model Invoice {
  id             String        @id @default(uuid())
  project_id     String
  amount         Decimal       @db.Decimal(12, 2)
  issue_date     DateTime?
  due_date       DateTime?
  status         InvoiceStatus @default(DRAFT)
  created_at     DateTime      @default(now())

  project        Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  payments       Payment[]
}

model Payment {
  id             String        @id @default(uuid())
  invoice_id     String
  amount         Decimal       @db.Decimal(12, 2)
  date           DateTime      @default(now())

  invoice        Invoice       @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
}

model RevenueSchedule {
  id                String        @id @default(uuid())
  project_id        String
  expected_amount   Decimal       @db.Decimal(12, 2)
  target_month      DateTime      // Store first day of month
  created_at        DateTime      @default(now())

  project           Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model Expense {
  id             String        @id @default(uuid())
  project_id     String
  amount         Decimal       @db.Decimal(12, 2)
  description    String
  date           DateTime      @default(now())

  project        Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

// =====================
// QBR / REPORTING MODULE
// =====================

model Quarter {
  id             String        @id @default(uuid())
  year           Int
  quarter_number Int           // 1, 2, 3, 4
  status         QuarterStatus @default(OPEN)
  created_at     DateTime      @default(now())
  closed_at      DateTime?

  snapshots           Snapshot[]
  executive_reports   ExecutiveReport[]
  
  @@unique([year, quarter_number])
}

model Snapshot {
  id             String          @id @default(uuid())
  quarter_id     String
  module         SnapshotModule
  data           Json            // Stores the JSONB snapshot
  created_at     DateTime        @default(now())

  quarter        Quarter         @relation(fields: [quarter_id], references: [id], onDelete: Cascade)
}

model ExecutiveReport {
  id             String        @id @default(uuid())
  quarter_id     String
  summary        String        @db.Text
  generated_at   DateTime      @default(now())

  quarter        Quarter       @relation(fields: [quarter_id], references: [id], onDelete: Cascade)
}
